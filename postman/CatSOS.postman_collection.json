{
  "info": {
    "_postman_id": "3dd17b2a-392e-49ef-aea8-7dca305b1147",
    "name": "CatSOS Local API",
    "description": "Grouped local Postman collection for CatSOS auth, Google SSO, and Microsoft SSO testing. Select the CatSOS Local environment before running requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Setup & Smoke",
      "description": "Start here. These requests confirm the local backend and selected environment are usable before testing authentication.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "health",
                ""
              ]
            },
            "description": "Confirms the Django backend is reachable before testing auth."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('health body is ok', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.eql('catsos-backend');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "10 - Email & Password Auth",
      "description": "Password registration, email verification, login, and CatSOS JWT refresh requests.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"password_confirm\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register",
                ""
              ]
            },
            "description": "Creates an unverified password account and sends the verification code to the backend console email output."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register returns created or validation conflict', function () {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"code\": \"{{verification_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-email/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-email",
                ""
              ]
            },
            "description": "Verifies an email code. On success, stores CatSOS access and refresh tokens in the active environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('verify email returns tokens', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('access');",
                  "  pm.expect(json).to.have.property('refresh');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('access_token', json.access);",
                  "  pm.environment.set('refresh_token', json.refresh);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login With Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"totp_code\": \"{{totp_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "token",
                ""
              ]
            },
            "description": "Logs in with email and password. Leave totp_code empty unless the account has authenticator-app verification enabled."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns tokens', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('access');",
                  "  pm.expect(json).to.have.property('refresh');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('access_token', json.access);",
                  "  pm.environment.set('refresh_token', json.refresh);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh CatSOS Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "token",
                "refresh",
                ""
              ]
            },
            "description": "Exchanges a CatSOS refresh token for a new access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('refresh returns a new access token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('access');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('access_token', pm.response.json().access);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "20 - Google SSO",
      "description": "Use the helper to obtain a Google ID token, then use that token with CatSOS SSO login or account linking.",
      "item": [
        {
          "name": "Google OAuth Helper (Get ID Token)",
          "request": {
            "auth": {
              "type": "oauth2",
              "oauth2": [
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "string"
                },
                {
                  "key": "callbackUrl",
                  "value": "{{oauth_callback_url}}",
                  "type": "string"
                },
                {
                  "key": "authUrl",
                  "value": "https://accounts.google.com/o/oauth2/v2/auth",
                  "type": "string"
                },
                {
                  "key": "accessTokenUrl",
                  "value": "https://oauth2.googleapis.com/token",
                  "type": "string"
                },
                {
                  "key": "clientId",
                  "value": "{{google_oauth_client_id}}",
                  "type": "string"
                },
                {
                  "key": "clientSecret",
                  "value": "{{google_oauth_client_secret}}",
                  "type": "string"
                },
                {
                  "key": "scope",
                  "value": "{{sso_oidc_scope}}",
                  "type": "string"
                },
                {
                  "key": "addTokenTo",
                  "value": "header",
                  "type": "string"
                },
                {
                  "key": "client_authentication",
                  "value": "body",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "health",
                ""
              ]
            },
            "description": "Helper request for Postman's Get New Access Token button. Copy id_token from the token details into google_id_token, then run Google SSO Login."
          }
        },
        {
          "name": "Google SSO Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"token\": \"{{google_id_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sso/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "sso",
                "login",
                ""
              ]
            },
            "description": "Logs in or signs up with a real Google ID token. Do not paste the Google access_token here."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Google SSO returns CatSOS JWTs', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token_type).to.eql('Bearer');",
                  "  pm.expect(json).to.have.property('access');",
                  "  pm.expect(json).to.have.property('refresh');",
                  "  pm.expect(json).to.have.property('user');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('access_token', json.access);",
                  "  pm.environment.set('refresh_token', json.refresh);",
                  "  if (json.user && json.user.email) {",
                  "    pm.environment.set('email', json.user.email);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Google SSO Link Current Account",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"token\": \"{{google_id_token}}\",\n  \"totp_code\": \"{{totp_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sso/link/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "sso",
                "link",
                ""
              ]
            },
            "description": "Links the Google identity to the currently authenticated CatSOS account. Requires a CatSOS access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('SSO link returns success or expected account conflict', function () {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "30 - Microsoft SSO",
      "description": "Use the helper to obtain a Microsoft ID token, then use that token with CatSOS SSO login or account linking.",
      "item": [
        {
          "name": "Microsoft OAuth Helper (Get ID Token)",
          "request": {
            "auth": {
              "type": "oauth2",
              "oauth2": [
                {
                  "key": "grant_type",
                  "value": "authorization_code_with_pkce",
                  "type": "string"
                },
                {
                  "key": "challengeAlgorithm",
                  "value": "S256",
                  "type": "string"
                },
                {
                  "key": "callbackUrl",
                  "value": "{{oauth_callback_url}}",
                  "type": "string"
                },
                {
                  "key": "authUrl",
                  "value": "https://login.microsoftonline.com/{{microsoft_tenant_id}}/oauth2/v2.0/authorize",
                  "type": "string"
                },
                {
                  "key": "accessTokenUrl",
                  "value": "https://login.microsoftonline.com/{{microsoft_tenant_id}}/oauth2/v2.0/token",
                  "type": "string"
                },
                {
                  "key": "clientId",
                  "value": "{{microsoft_oauth_client_id}}",
                  "type": "string"
                },
                {
                  "key": "scope",
                  "value": "{{sso_oidc_scope}}",
                  "type": "string"
                },
                {
                  "key": "addTokenTo",
                  "value": "header",
                  "type": "string"
                },
                {
                  "key": "client_authentication",
                  "value": "none",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "health",
                ""
              ]
            },
            "description": "Helper request for Postman's Get New Access Token button. Copy id_token from the token details into microsoft_id_token, then run Microsoft SSO Login."
          }
        },
        {
          "name": "Microsoft SSO Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"microsoft\",\n  \"token\": \"{{microsoft_id_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sso/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "sso",
                "login",
                ""
              ]
            },
            "description": "Logs in or signs up with a real Microsoft ID token. Do not paste a Microsoft Graph access_token here."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Microsoft SSO returns CatSOS JWTs', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token_type).to.eql('Bearer');",
                  "  pm.expect(json).to.have.property('access');",
                  "  pm.expect(json).to.have.property('refresh');",
                  "  pm.expect(json).to.have.property('user');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('access_token', json.access);",
                  "  pm.environment.set('refresh_token', json.refresh);",
                  "  if (json.user && json.user.email) {",
                  "    pm.environment.set('email', json.user.email);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Microsoft SSO Link Current Account",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"microsoft\",\n  \"token\": \"{{microsoft_id_token}}\",\n  \"totp_code\": \"{{totp_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sso/link/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "sso",
                "link",
                ""
              ]
            },
            "description": "Links the Microsoft identity to the currently authenticated CatSOS account. Requires a CatSOS access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('SSO link returns success or expected account conflict', function () {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
