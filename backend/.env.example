# CatSOS backend local environment
#
# Copy this file to backend/.env for local development:
#   Copy-Item backend\.env.example backend\.env
#
# Do not commit real secrets. Keep comments on their own lines; inline comments
# after values are treated as part of the value.


# -----------------------------------------------------------------------------
# Core Django settings
# -----------------------------------------------------------------------------

DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-for-non-local-use
DJANGO_ALLOWED_HOSTS=localhost,backend


# -----------------------------------------------------------------------------
# Frontend and browser integration
# -----------------------------------------------------------------------------

DJANGO_FRONTEND_URL=http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173


# -----------------------------------------------------------------------------
# Email delivery
# -----------------------------------------------------------------------------

# Local default: print emails in the Django console instead of sending them.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@catsos.local

# SMTP settings are used when DJANGO_EMAIL_BACKEND is:
# django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_EMAIL_TIMEOUT=10


# -----------------------------------------------------------------------------
# Account verification and password recovery
# -----------------------------------------------------------------------------

DJANGO_ACCOUNT_VERIFICATION_RESEND_SECONDS=120
DJANGO_PASSWORD_RESET_TIMEOUT=3600
DJANGO_PASSWORD_RESET_EMAIL_RATE_LIMIT_PER_HOUR=5
DJANGO_PASSWORD_RESET_IP_RATE_LIMIT_PER_HOUR=10


# -----------------------------------------------------------------------------
# Account profile media
# -----------------------------------------------------------------------------

DJANGO_PROFILE_PICTURE_MAX_SIZE_BYTES=5242880


# -----------------------------------------------------------------------------
# TOTP authenticator app settings
# -----------------------------------------------------------------------------

DJANGO_TOTP_ISSUER_NAME=CatSOS
DJANGO_TOTP_STEP_SECONDS=30
DJANGO_TOTP_DIGITS=6
DJANGO_TOTP_WINDOW=1


# -----------------------------------------------------------------------------
# Single sign-on providers
# -----------------------------------------------------------------------------

# Google OAuth setup:
# 1. In Google Cloud Console, open Google Auth Platform > Clients.
# 2. Create a Web application client.
# 3. Add http://localhost:5173 as a JavaScript origin.
# 4. Copy the generated client ID here. Do not use the client secret.
GOOGLE_OAUTH_CLIENT_ID=

# Microsoft OAuth setup:
# 1. Open https://entra.microsoft.com and search for App registrations.
# 2. Create a New registration. If search fails, try Entra ID > App registrations.
# 3. Add http://localhost:5173/auth/callback/microsoft as a Single-page application redirect URI.
# 4. Copy the Application (client) ID here. Do not use a client secret for the frontend flow.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_JWKS_URL=https://login.microsoftonline.com/common/discovery/v2.0/keys
DJANGO_SSO_HTTP_TIMEOUT_SECONDS=5


# -----------------------------------------------------------------------------
# Auth endpoint throttles
# -----------------------------------------------------------------------------

DJANGO_AUTH_REGISTER_RATE=20/hour
DJANGO_AUTH_VERIFY_RATE=30/minute
DJANGO_AUTH_RESEND_RATE=10/hour
DJANGO_AUTH_CHANGE_EMAIL_RATE=10/hour
DJANGO_AUTH_LOGIN_RATE=20/minute
DJANGO_AUTH_TOKEN_REFRESH_RATE=60/minute
DJANGO_AUTH_SSO_LOGIN_RATE=20/minute
DJANGO_AUTH_SSO_LINK_RATE=20/minute
DJANGO_PUBLIC_PROFILE_RATE=120/minute
DJANGO_LOST_REPORT_READ_RATE=120/minute
DJANGO_LOST_REPORT_WRITE_RATE=30/minute
