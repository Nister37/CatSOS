# CatSOS Frontend Environment Variables
# Copy this file to .env and fill in real values.

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Google OAuth 2.0 Client ID (from Google Cloud Console)
# Required for Google SSO login/signup
VITE_GOOGLE_CLIENT_ID=

# Microsoft OAuth 2.0 Application (client) ID (from Azure Portal / Entra ID)
# Required for Microsoft SSO login/signup
VITE_MICROSOFT_CLIENT_ID=

# Microsoft tenant ID (optional — defaults to "common" for multi-tenant)
VITE_MICROSOFT_TENANT_ID=common
